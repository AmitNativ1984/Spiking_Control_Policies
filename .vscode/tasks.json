{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Train MLP",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_mlp.yaml",
                "--train",
                "--num_envs=4096",
                "--headless=True"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train Hover PopSAN",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_popsan.yaml",
                "--train",
                "--num_envs=2048",
                "--headless=True"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train MLP (with checkpoint)",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_mlp.yaml",
                "--train",
                "--num_envs=4096",
                "--headless=True",
                "--checkpoint=${input:mlpCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train SNN",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_snn.yaml",
                "--train",
                "--num_envs=4096",
                "--headless=True"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train SNN (with checkpoint)",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_snn.yaml",
                "--train",
                "--num_envs=4096",
                "--headless=True",
                "--checkpoint=${input:snnCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Play MLP",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_mlp.yaml",
                "--play",
                "--num_envs=64",
                "--headless=False",
                "--checkpoint=${input:mlpCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "Play SNN",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_snn.yaml",
                "--play",
                "--num_envs=64",
                "--headless=False",
                "--checkpoint=${input:snnCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "Play Hover PopSAN",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_popsan.yaml",
                "--play",
                "--num_envs=64",
                "--headless=False",
                "--checkpoint=${input:snnCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "PLOT ENCODING Hover PopSAN",
            "type": "shell",
            "command": "python",
            "args": [
                "simple_hover_snn/training/runner.py",
                "--file=simple_hover_snn/training/ppo_hover_popsan.yaml",
                "--play",
                "--num_envs=64",
                "--headless=False",
                "--plot-encoding",
                "--checkpoint=${input:snnCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train Navigation VAE ANN",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.runner",
                "--file=navigation_with_obstacles/training/ppo_navigation_ann_local.yaml",
                "--train",
                "--headless=True"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train Navigation POPSAN",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.runner",
                "--file=navigation_with_obstacles/training/popsan_navigation_local.yaml",
                "--train",
                "--headless=True"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Play Navigation POPSAN",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.runner",
                "--file=navigation_with_obstacles/training/popsan_navigation_local.yaml",
                "--play",
                "--num_envs=1",
                "--plot-encoding",
                "--checkpoint=${input:navCheckpoint}",
                "--headless=False",
                "--curriculum_level=${input:navCurriculum}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Train Navigation (with checkpoint)",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.runner",
                "--file=navigation_with_obstacles/training/ppo_navigation.yaml",
                "--train",
                "--headless=True",
                "--checkpoint=${input:navCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Play Navigation",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.runner",
                "--file=navigation_with_obstacles/training/ppo_navigation.yaml",
                "--play",
                "--num_envs=1",
                "--headless=False",
                "--checkpoint=${input:navCheckpoint}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "Train Teacher-Student Warmup",
            "type": "shell",
            "command": "python",
            "args": [
                "-m",
                "navigation_with_obstacles.training.warmup_snn_from_ann",
                "--file=navigation_with_obstacles/training/popsan_teacher_student_local.yaml",
                "--headless=True",
                "--bounds_episodes=500",
                "--bounds_envs=16",
                "--eval",
                "--eval_max_step=400",
                "--max_steps=100000",
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "mlpCheckpoint",
            "type": "promptString",
            "description": "Path to MLP checkpoint (e.g., runs/simple_hover_mlp_xxx/nn/simple_hover_mlp.pth)"
        },
        {
            "id": "snnCheckpoint",
            "type": "promptString",
            "description": "Path to SNN checkpoint (e.g., runs/simple_hover_snn_xxx/nn/simple_hover_snn.pth)"
        },
        {
            "id": "navCheckpoint",
            "type": "promptString",
            "description": "Path to Navigation checkpoint (e.g., runs/navigation_with_obstacles_xxx/nn/navigation_with_obstacles.pth)"
        },
        {
            "id": "navCurriculum",
            "type": "promptString",
            "description": "Curriculum level for Navigation (e.g., 0, 1, 2, ...)"
        }
    ]
}
